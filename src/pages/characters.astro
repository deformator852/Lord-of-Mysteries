---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;
const image = (name: string) => `${base}images/${name}`.replace(/\/+/g, "/");

const characters = [
  { name: "Klein Moretti", alias: "The Fool", group: "tarot", role: "Seer Pathway", mark: "♛", image: "klein-portrait.webp", bio: "A transmigrator who awakens in Tingen and establishes the Tarot Club from above the gray fog." },
  { name: "Audrey Hall", alias: "Justice", group: "tarot", role: "Spectator Pathway", mark: "♢", image: "tarot-club-portrait.webp", bio: "A perceptive noblewoman whose bright curiosity conceals a formidable understanding of the mind." },
  { name: "Alger Wilson", alias: "The Hanged Man", group: "tarot", role: "Sailor Pathway", mark: "♆", image: "alger-portrait.webp", bio: "A calculating seafarer of the Church of Storms and one of the Tarot Club's founding members." },
  { name: "Derrick Berg", alias: "The Sun", group: "tarot", role: "Sun Pathway", mark: "☼", image: "derrick-portrait.webp", bio: "A sincere youth from the forsaken City of Silver, searching for hope beneath an endless darkness." },
  { name: "Leonard Mitchell", alias: "The Star", group: "night", role: "Sleepless Pathway", mark: "★", image: "leonard-portrait.webp", bio: "A poetic Nighthawk with an old soul, a careless smile, and secrets hidden within his body." },
  { name: "Daly Simone", alias: "Spirit Medium", group: "night", role: "Death Pathway", mark: "☾", image: "daly-portrait.webp", bio: "A gifted spirit medium whose irreverent humor shields deep loyalty and grief." },
  { name: "Dunn Smith", alias: "Captain", group: "night", role: "Sleepless Pathway", mark: "◈", image: "nighthawks-portrait.webp", bio: "The steady captain of Tingen's Nighthawks, remembered for his calm presence and quiet sacrifice." },
  { name: "Roselle Gustav", alias: "Emperor Roselle", group: "historical", role: "Savant Pathway", mark: "♜", image: "roselle-portrait.webp", bio: "An era-defining emperor, inventor, and fellow transmigrator whose diaries reshape Klein's understanding." },
  { name: "Azik Eggers", alias: "Mr. Azik", group: "historical", role: "Death Pathway", mark: "✦", image: "azik-portrait.webp", bio: "A gentle history teacher haunted by lost memories and a connection to the ancient underworld." },
];
---

<BaseLayout
  title="Characters"
  description="Explore key Lord of Mysteries characters, from the Tarot Club to the Nighthawks."
  page="characters"
>
  <section class="page-hero">
    <div class="page-hero__inner">
      <p class="eyebrow" data-reveal>Archive I</p>
      <h1 class="display-title" data-reveal>Figures in<br /><em>the Fog</em></h1>
      <p class="lede" data-reveal>Seekers, guardians, and legends drawn together by coincidence—or by something far older.</p>
      <span class="page-hero__index" aria-hidden="true">I</span>
    </div>
  </section>

  <section class="content-shell">
    <div class="feature-banner" data-reveal>
      <img src={image("nighthawks-portrait.webp")} alt="The Nighthawks standing in a rain-soaked city" />
      <div>
        <small>BLACKTHORN SECURITY COMPANY · TINGEN</small>
        <h2>Guardians of the Night</h2>
        <p>Officially, they are a security company. In truth, the Nighthawks are Beyonders who stand between ordinary people and horrors that should remain unseen.</p>
      </div>
    </div>

    <div class="filter-bar" data-reveal aria-label="Filter characters">
      <button class="filter-button active" type="button" data-filter="all">All Records</button>
      <button class="filter-button" type="button" data-filter="tarot">Tarot Club</button>
      <button class="filter-button" type="button" data-filter="night">Nighthawks</button>
      <button class="filter-button" type="button" data-filter="historical">Historical</button>
    </div>

    <div class="character-grid">
      {characters.map((character, index) => (
        <article
          class={`character-card reveal-delay-${index % 3}`}
          data-group={character.group}
          data-reveal
        >
          <img class="character-card__image" src={image(character.image)} alt={`Portrait of ${character.name}`} loading="lazy" />
          <span class="character-card__mark" aria-hidden="true">{character.mark}</span>
          <div class="character-card__shade"></div>
          <div class="character-card__meta">
            <span>{character.alias}</span>
            <span>{character.role}</span>
          </div>
          <h2>{character.name}</h2>
          <p>{character.bio}</p>
        </article>
      ))}
    </div>
  </section>

  <script is:inline>
    const filters = document.querySelectorAll("[data-filter]");
    const cards = document.querySelectorAll(".character-card");
    filters.forEach((button) => {
      button.addEventListener("click", () => {
        filters.forEach((item) => item.classList.remove("active"));
        button.classList.add("active");
        const group = button.dataset.filter;
        cards.forEach((card) => card.classList.toggle("is-hidden", group !== "all" && card.dataset.group !== group));
      });
    });
  </script>
</BaseLayout>
